<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ProxyBridge.GUI.App"
             RequestedThemeVariant="Light">
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Styles/SharedStyles.axaml"/>
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/logo.ico"
                      ToolTipText="CloudSmartIP">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="显示主界面" Click="TrayIcon_Show" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="退出" Click="TrayIcon_Exit" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
